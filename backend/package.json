{
  "name": "lumiere-salon-api",
  "version": "1.0.0",
  "description": "Lumière Salon — Production REST API (Node.js + Express)",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
