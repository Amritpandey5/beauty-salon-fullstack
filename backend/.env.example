# ─────────────────────────────────────────────
# Lumière Salon API — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/lumiere_salon

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production_min_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# Cookie
COOKIE_SECRET=your_cookie_secret_key

# CORS — Frontend origin
CLIENT_URL=http://localhost:5173

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Lumière Salon <noreply@lumierekuwait.com>

# Admin seed account
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@lumierekuwait.com
ADMIN_PASSWORD=Admin@Lumiere2025!

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
